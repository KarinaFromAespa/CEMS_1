@page "/admin/participants"
@rendermode InteractiveServer
@inject AppDbContext Db
@inject IParticipantService ParticipantSvc

<h3>Participants</h3>
<button class="btn btn-success mb-3" @onclick="OpenAddForm">+ Add Participant</button>

@if (showForm)
{
    <div class="card mb-4 p-3 shadow-sm">
        <h5>@(editingId == null ? "New Participant" : "Edit Participant")</h5>
        <div class="mb-2">
            <label>Full Name</label>
            <input class="form-control" @bind="form.Name" />
        </div>
        <div class="mb-2">
            <label>Email</label>
            <input type="email" class="form-control" @bind="form.Email" />
        </div>
        <div class="mb-2">
            <label>Phone</label>
            <input type="tel" class="form-control" @bind="form.Phone" placeholder="+447700123456" />
        </div>
        @if (!string.IsNullOrEmpty(formError))
        {
            <div class="alert alert-danger py-1">@formError</div>
        }
        <div class="mt-2">
            <button class="btn btn-primary me-2" @onclick="SaveParticipant">Save</button>
            <button class="btn btn-secondary" @onclick="CancelForm">Cancel</button>
        </div>
    </div>
}

@if (resetPasswordId.HasValue)
{
    <div class="card mb-4 p-3 shadow-sm border-warning">
        <h5>Reset Password for <strong>@resetPasswordName</strong></h5>
        <div class="mb-2">
            <label>New Password</label>
            <input type="password" class="form-control" @bind="resetNewPassword" />
            <div class="form-text text-muted">Min 8 chars, must include uppercase, lowercase, number and special character.</div>
        </div>
        <div class="mb-2">
            <label>Confirm New Password</label>
            <input type="password" class="form-control" @bind="resetConfirmPassword" />
        </div>
        @if (!string.IsNullOrEmpty(resetError))
        {
            <div class="alert alert-danger py-1">@resetError</div>
        }
        @if (!string.IsNullOrEmpty(resetSuccess))
        {
            <div class="alert alert-success py-1">@resetSuccess</div>
        }
        <div class="mt-2">
            <button class="btn btn-warning me-2" @onclick="DoResetPassword">Reset Password</button>
            <button class="btn btn-secondary" @onclick="CancelReset">Cancel</button>
        </div>
    </div>
}

<table class="table table-hover">
    <thead class="table-dark">
        <tr><th>Name</th><th>Email</th><th>Phone</th><th>Registrations</th><th>Actions</th></tr>
    </thead>
    <tbody>
        @foreach (var p in participants)
        {
            <tr>
                <td>@p.Name</td>
                <td>@p.Email</td>
                <td>@p.Phone</td>
                <td>@p.Registrations.Count</td>
                <td>
                    <button class="btn btn-sm btn-warning me-1" @onclick="() => StartEdit(p)">Edit</button>
                    <button class="btn btn-sm btn-info me-1 text-white" @onclick="() => StartResetPassword(p)">Reset PW</button>
                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteParticipant(p.ParticipantId)">Delete</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    [Inject] private SessionService Session { get; set; } = default!;
    [Inject] private NavigationManager NavigationManager { get; set; } = default!;
    private List<Participant> participants = new();
    private Participant form = new();
    private int? editingId;
    private bool showForm;
    private string formError = "";

    // Reset password state
    private int? resetPasswordId;
    private string resetPasswordName = "";
    private string resetNewPassword = "";
    private string resetConfirmPassword = "";
    private string resetError = "";
    private string resetSuccess = "";

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAdmin)
        {
            NavigationManager.NavigateTo("/admin/login");
            return;
        }
        participants = await Db.Participants
            .Include(p => p.Registrations)
            .ToListAsync();
    }

    private void OpenAddForm()
    {
        showForm = true;
        editingId = null;
        form = new();
        formError = "";
        resetPasswordId = null;
    }

    private void StartEdit(Participant p)
    {
        editingId = p.ParticipantId;
        form = new Participant { Name = p.Name, Email = p.Email, Phone = p.Phone };
        showForm = true;
        resetPasswordId = null;
        resetError = "";
        resetSuccess = "";
    }

    private void StartResetPassword(Participant p)
    {
        resetPasswordId = p.ParticipantId;
        resetPasswordName = p.Name;
        resetNewPassword = "";
        resetConfirmPassword = "";
        resetError = "";
        resetSuccess = "";
        showForm = false;
    }

    private void CancelForm()
    {
        showForm = false;
        editingId = null;
        form = new();
        formError = "";
    }

    private void CancelReset()
    {
        resetPasswordId = null;
        resetNewPassword = "";
        resetConfirmPassword = "";
        resetError = "";
        resetSuccess = "";
    }

    private bool IsValidEmail(string email)
    {
        try
        {
            var addr = new System.Net.Mail.MailAddress(email);
            // Must have a dot in the domain part
            var domain = addr.Host;
            return addr.Address == email && domain.Contains('.');
        }
        catch
        {
            return false;
        }
    }

    private bool IsValidPassword(string password, out string pwError)
    {
        pwError = "";
        if (password.Length < 8) { pwError = "Password must be at least 8 characters."; return false; }
        if (!password.Any(char.IsUpper)) { pwError = "Password must contain at least one uppercase letter."; return false; }
        if (!password.Any(char.IsLower)) { pwError = "Password must contain at least one lowercase letter."; return false; }
        if (!password.Any(char.IsDigit)) { pwError = "Password must contain at least one number."; return false; }
        if (!password.Any(c => !char.IsLetterOrDigit(c))) { pwError = "Password must contain at least one special character."; return false; }
        return true;
    }

    private bool IsValidPhone(string ph, out string phError)
    {
        phError = "";
        var digits = ph.Replace(" ", "").Replace("-", "");
        if (!digits.StartsWith("+"))
        {
            phError = "Phone number must start with a country code (e.g. +44).";
            return false;
        }
        var afterPlus = digits.Substring(1);
        if (!afterPlus.All(char.IsDigit))
        {
            phError = "Phone number may only contain digits after the country code prefix.";
            return false;
        }
        if (afterPlus.Length < 11 || afterPlus.Length > 13)
        {
            phError = "Phone number must have a country code plus 10 digits (e.g. +447700123456).";
            return false;
        }
        return true;
    }

    private async Task SaveParticipant()
    {
        formError = "";
        if (string.IsNullOrWhiteSpace(form.Name)) { formError = "Name is required."; return; }
        if (string.IsNullOrWhiteSpace(form.Email)) { formError = "Email is required."; return; }
        if (!IsValidEmail(form.Email)) { formError = "Enter a valid email address (e.g. user@example.com)."; return; }
        if (!string.IsNullOrWhiteSpace(form.Phone) && !IsValidPhone(form.Phone.Trim(), out var phError)) { formError = phError; return; }

        try
        {
            if (editingId.HasValue)
            {
                var existing = await Db.Participants.FindAsync(editingId.Value);
                if (existing != null)
                {
                    existing.Name = form.Name;
                    existing.Email = form.Email;
                    existing.Phone = form.Phone;
                }
            }
            else
            {
                bool emailExists = await Db.Participants.AnyAsync(p => p.Email == form.Email);
                if (emailExists) { formError = "A participant with this email already exists."; return; }

                Db.Participants.Add(form);
            }

            await Db.SaveChangesAsync();
            participants = await Db.Participants.Include(p => p.Registrations).ToListAsync();
            CancelForm();
        }
        catch (Exception ex)
        {
            formError = $"Error: {ex.Message}";
        }
    }

    private async Task DoResetPassword()
    {
        resetError = "";
        resetSuccess = "";

        if (string.IsNullOrWhiteSpace(resetNewPassword)) { resetError = "Password is required."; return; }
        if (!IsValidPassword(resetNewPassword, out var pwError)) { resetError = pwError; return; }
        if (resetNewPassword != resetConfirmPassword) { resetError = "Passwords do not match."; return; }

        var ok = await ParticipantSvc.ResetPasswordAsync(resetPasswordId!.Value, resetNewPassword);
        if (ok)
        {
            resetSuccess = $"Password for {resetPasswordName} has been reset successfully.";
            resetNewPassword = "";
            resetConfirmPassword = "";
        }
        else
        {
            resetError = "Failed to reset password. Participant not found.";
        }
    }

    private async Task DeleteParticipant(int id)
    {
        var p = await Db.Participants.FindAsync(id);
        if (p != null) { Db.Participants.Remove(p); await Db.SaveChangesAsync(); }
        participants = await Db.Participants.Include(p => p.Registrations).ToListAsync();
    }
}
