@page "/account"
@rendermode InteractiveServer
@inject AppDbContext Db
@inject SessionService Session
@inject NavigationManager Nav

@if (!Session.IsLoggedIn)
{
    <p>Redirecting...</p>
}
else if (participant == null)
{
    <p>Loading...</p>
}
else
{
    <div class="row mt-2">
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">👤 My Profile</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Name</dt>
                        <dd class="col-sm-8">@participant.Name</dd>

                        <dt class="col-sm-4">Email</dt>
                        <dd class="col-sm-8">@participant.Email</dd>

                        <dt class="col-sm-4">Phone</dt>
                        <dd class="col-sm-8">@participant.Phone</dd>

                        <dt class="col-sm-4">Member since</dt>
                        <dd class="col-sm-8">@participant.CreatedAt.ToString("dd MMM yyyy")</dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">📋 My Registrations</h5>
                    <a href="/register" class="btn btn-sm btn-light">+ Register for Event</a>
                </div>
                <div class="card-body p-0">
                    @if (!registrations.Any())
                    {
                        <p class="text-muted p-3 mb-0">You have no event registrations yet.</p>
                    }
                    else
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>Event</th>
                                    <th>Date</th>
                                    <th>Venue</th>
                                    <th>Status</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var reg in registrations)
                                {
                                    <tr>
                                        <td>@reg.Event?.Name</td>
                                        <td>@reg.Event?.Date.ToString("dd MMM yyyy")</td>
                                        <td>@reg.Event?.Venue?.Name</td>
                                        <td>
                                            <span class="badge bg-@StatusColor(reg.Status)">@reg.Status</span>
                                        </td>
                                        <td>
                                            @if (reg.Status != "Cancelled")
                                            {
                                                <button class="btn btn-sm btn-outline-danger"
                                                        @onclick="() => PromptCancel(reg.RegistrationId, reg.Event?.Name)">
                                                    Cancel
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>
}

@if (showCancelConfirm)
{
    <div class="modal-backdrop fade show" style="z-index:1040;"></div>
    <div class="modal fade show d-block" style="z-index:1050;" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Cancel Registration</h5>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to cancel your registration for <strong>@cancelEventName</strong>?</p>
                    <p class="text-muted small mb-0">This action cannot be undone without re-registering.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showCancelConfirm = false">Keep Registration</button>
                    <button class="btn btn-danger" @onclick="ConfirmCancel">Yes, Cancel Registration</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private Participant? participant;
    private List<Registration> registrations = new();

    private bool showCancelConfirm = false;
    private int pendingCancelId = 0;
    private string cancelEventName = "";

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsLoggedIn)
        {
            Nav.NavigateTo("/login");
            return;
        }

        participant = await Db.Participants.FindAsync(Session.CurrentParticipantId);

        registrations = await Db.Registrations
            .Include(r => r.Event).ThenInclude(e => e!.Venue)
            .Where(r => r.ParticipantId == Session.CurrentParticipantId)
            .OrderByDescending(r => r.RegistrationDate)
            .ToListAsync();
    }

    private void PromptCancel(int id, string? eventName)
    {
        pendingCancelId = id;
        cancelEventName = eventName ?? "this event";
        showCancelConfirm = true;
    }

    private async Task ConfirmCancel()
    {
        showCancelConfirm = false;
        var reg = await Db.Registrations.FindAsync(pendingCancelId);
        if (reg != null && reg.ParticipantId == Session.CurrentParticipantId)
        {
            reg.Status = "Cancelled";
            await Db.SaveChangesAsync();
            registrations = await Db.Registrations
                .Include(r => r.Event).ThenInclude(e => e!.Venue)
                .Where(r => r.ParticipantId == Session.CurrentParticipantId)
                .OrderByDescending(r => r.RegistrationDate)
                .ToListAsync();
        }
    }

    private void Logout()
    {
        Session.LogoutParticipant();
        Nav.NavigateTo("/");
    }

    private string StatusColor(string status) => status switch
    {
        "Confirmed" => "success",
        "Cancelled" => "danger",
        "Waitlisted" => "warning",
        "Pending" => "secondary",
        _ => "secondary"
    };
}
