@page "/signup"
@rendermode InteractiveServer
@inject AppDbContext Db
@inject SessionService Session
@inject NavigationManager Nav

<div class="row justify-content-center mt-4">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-header bg-success text-white text-center">
                <h4 class="mb-0">Create Account</h4>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Full Name</label>
                    <input class="form-control" @bind="name" placeholder="Jane Smith" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-control" @bind="email" placeholder="jane@example.com" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Phone</label>
                    <input type="tel" class="form-control" @bind="phone" placeholder="07700123456" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <input type="password" class="form-control" @bind="password" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Confirm Password</label>
                    <input type="password" class="form-control" @bind="confirmPassword" />
                </div>

                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="alert alert-danger py-2">@error</div>
                }

                <button class="btn btn-success w-100" @onclick="DoSignup">Create Account</button>
                <p class="text-center mt-3 mb-0 text-muted small">
                    Already have an account? <a href="/login">Log in</a>
                </p>
            </div>
        </div>
    </div>
</div>

@code {
    private string name = "", email = "", phone = "", password = "", confirmPassword = "";
    private string error = "";

    protected override void OnInitialized()
    {
        if (Session.IsLoggedIn) Nav.NavigateTo("/account");
    }

    private async Task DoSignup()
    {
        error = "";

        if (string.IsNullOrWhiteSpace(name)) { error = "Name is required."; return; }
        if (string.IsNullOrWhiteSpace(email) || !email.Contains('@')) { error = "A valid email is required."; return; }
        if (string.IsNullOrWhiteSpace(phone)) { error = "Phone number is required."; return; }
        if (password.Length < 6) { error = "Password must be at least 6 characters."; return; }
        if (password != confirmPassword) { error = "Passwords do not match."; return; }

        bool emailTaken = await Db.Participants.AnyAsync(p => p.Email == email.Trim().ToLower());
        if (emailTaken) { error = "An account with that email already exists."; return; }

        var participant = new Participant
        {
            Name = name.Trim(),
            Email = email.Trim().ToLower(),
            Phone = phone.Trim(),
            PasswordHash = BCrypt.Net.BCrypt.HashPassword(password),
            CreatedAt = DateTime.UtcNow
        };

        Db.Participants.Add(participant);
        await Db.SaveChangesAsync();

        Session.LoginParticipant(participant.ParticipantId, participant.Name);
        Nav.NavigateTo("/account");
    }
}
