@page "/admin/activities"
@rendermode InteractiveServer
@inject AppDbContext Db

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold">Activities</h3>
    <button class="btn btn-success" @onclick="() => showForm = true">
        <i class="bi bi-plus-lg me-1"></i> Add Activity
    </button>
</div>

@if (showForm)
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h5 class="card-title mb-3">@(editingId == null ? "New Activity" : "Edit Activity")</h5>
            <div class="mb-3">
                <label class="form-label">Name</label>
                <input class="form-control" @bind="form.Name" placeholder="e.g., Coding Workshop" />
            </div>
            <div class="mb-3">
                <label class="form-label">Type</label>
                <select class="form-select" @bind="form.Type">
                    <option value="">-- Select Type --</option>
                    <option>Workshop</option>
                    <option>Talk</option>
                    <option>Game</option>
                    <option>Other</option>
                </select>
            </div>
            @if (!string.IsNullOrEmpty(formError))
            {
                <div class="alert alert-danger py-2">@formError</div>
            }
            <div class="d-flex gap-2">
                <button class="btn btn-primary" @onclick="SaveActivity">Save</button>
                <button class="btn btn-outline-secondary" @onclick="CancelForm">Cancel</button>
            </div>
        </div>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr><th>Name</th><th>Type</th><th class="text-end">Actions</th></tr>
            </thead>
            <tbody>
                @foreach (var a in activities)
                {
                    <tr>
                        <td>@a.Name</td>
                        <td><span class="badge bg-secondary">@a.Type</span></td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-warning me-1" @onclick="() => StartEdit(a)">Edit</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteActivity(a.ActivityId)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    [Inject] private SessionService Session { get; set; } = default!;
    [Inject] private NavigationManager NavigationManager { get; set; } = default!;

    private List<Activity> activities = new();
    private Activity form = new();
    private int? editingId;
    private bool showForm;
    private string formError = "";

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAdmin)
        {
            NavigationManager.NavigateTo("/admin/login");
            return;
        }
        activities = await Db.Activities.ToListAsync();
    }

    private void StartEdit(Activity a)
    {
        editingId = a.ActivityId;
        form = new Activity { Name = a.Name, Type = a.Type };
        showForm = true;
    }

    private void CancelForm()
    {
        showForm = false;
        editingId = null;
        form = new();
        formError = "";
    }

    private async Task SaveActivity()
    {
        formError = "";
        if (string.IsNullOrWhiteSpace(form.Name)) { formError = "Name is required."; return; }
        if (string.IsNullOrWhiteSpace(form.Type)) { formError = "Type is required."; return; }

        try
        {
            if (editingId.HasValue)
            {
                var existing = await Db.Activities.FindAsync(editingId.Value);
                if (existing != null) { existing.Name = form.Name; existing.Type = form.Type; }
            }
            else
            {
                Db.Activities.Add(form);
            }

            await Db.SaveChangesAsync();
            activities = await Db.Activities.ToListAsync();
            CancelForm();
        }
        catch (Exception ex)
        {
            formError = $"Error: {ex.Message}";
        }
    }

    private async Task DeleteActivity(int id)
    {
        var a = await Db.Activities.FindAsync(id);
        if (a != null) { Db.Activities.Remove(a); await Db.SaveChangesAsync(); }
        activities = await Db.Activities.ToListAsync();
    }
}