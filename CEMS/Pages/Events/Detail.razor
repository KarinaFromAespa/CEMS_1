@page "/admin/events/{Id:int}"
@rendermode InteractiveServer
@inject IEventService EventService
@inject NavigationManager Nav
@using CEMS.Services

@if (evt == null)
{
    <p>Loading...</p>
}
else
{
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0">@evt.Name</h4>
        </div>
        <div class="card-body">
            <p><strong>Date:</strong> @evt.Date.ToString("dddd, dd MMMM yyyy") at @evt.Time.ToString(@"hh\:mm")</p>
            <p><strong>Venue:</strong> @evt.Venue?.Name — @evt.Venue?.Address (Capacity: @evt.Venue?.Capacity)</p>
            <p><strong>Description:</strong> @evt.Description</p>

            <h5 class="mt-3">Activities</h5>
            @if (evt.EventActivities.Any())
            {
                <ul>
                    @foreach (var ea in evt.EventActivities)
                    {
                        <li>@ea.Activity?.Name <span class="badge bg-secondary">@ea.Activity?.Type</span></li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">No activities listed.</p>
            }

            <h5 class="mt-3">Registered Participants (@evt.Registrations.Count)</h5>
            @if (evt.Registrations.Any())
            {
                <table class="table table-sm">
                    <thead>
                        <tr><th>Name</th><th>Email</th><th>Status</th><th>Registered</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var reg in evt.Registrations)
                        {
                            <tr>
                                <td>@reg.Participant?.Name</td>
                                <td>@reg.Participant?.Email</td>
                                <td><span class="badge bg-@StatusColor(reg.Status)">@reg.Status</span></td>
                                <td>@reg.RegistrationDate.ToString("dd MMM yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted">No registrations yet.</p>
            }
        </div>
        <div class="card-footer">
            <button class="btn btn-warning me-2" @onclick='() => Nav.NavigateTo($"/events/edit/{evt.EventId}")'>Edit</button>
            <button class="btn btn-secondary" @onclick='() => Nav.NavigateTo("/events")'>Back</button>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private Event? evt;

    protected override async Task OnInitializedAsync() =>
        evt = await EventService.GetEventByIdAsync(Id);

    private string StatusColor(string status) => status switch
    {
        "Confirmed" => "success",
        "Cancelled" => "danger",
        "Waitlisted" => "warning",
        _ => "secondary"
    };
}